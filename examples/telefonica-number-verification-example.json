{
  "request": {
    "method": "POST",
    "url": "https://opengateway.telefonica.com/v1/number-verification/verify",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "phoneNumber": "+34123456789"
    }
  },
  "response": {
    "status": 200,
    "body": {
      "devicePhoneNumberVerified": true
    }
  }
}
