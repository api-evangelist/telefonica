{
  "request": {
    "method": "POST",
    "url": "https://opengateway.telefonica.com/v1/sim-swap/check",
    "headers": {
      "Authorization": "Bearer {access_token}",
      "Content-Type": "application/json"
    },
    "body": {
      "phoneNumber": "+34123456789",
      "maxAge": 240
    }
  },
  "response": {
    "status": 200,
    "body": {
      "swapped": false
    }
  }
}
